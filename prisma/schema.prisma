generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Venue {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Basic Info
  name      String
  slug      String  @unique
  street    String?
  city      String
  state     String  @default("CA")
  stateSlug String @default("california")
  zip       String?
  latitude  Float?
  longitude Float?
  website   String?
  phone     String?
  email     String?
  instagram String?
  facebook  String?
  tiktok    String?

  // Type & Style
  venueType String
  styleTags String[]

  // Capacity
  minGuests    Int?
  maxGuests    Int?
  seatedMax    Int?
  standingMax  Int?
  ceremonyOnly Boolean @default(false)

  // Pricing
  baseRentalMin   Int?
  baseRentalMax   Int?
  priceTier       String? // "budget" | "moderate" | "luxury"
  perHeadMin      Int?
  perHeadMax      Int?
  depositPercent  Int?
  peakPricing     Boolean @default(false)
  offPeakDiscount Boolean @default(false)
  allInclusive    Boolean @default(false)

  // Spaces
  spacesDescription String?
  hasBridalSuite    Boolean @default(false)
  hasGroomSuite     Boolean @default(false)
  hasOutdoorSpace   Boolean @default(false)
  hasIndoorSpace    Boolean @default(false)
  parkingSpots      Int?

  // What's Included
  tablesChairsIncluded    Boolean @default(false)
  linensIncluded          Boolean @default(false)
  avIncluded              Boolean @default(false)
  lightingIncluded        Boolean @default(false)
  cateringKitchen         Boolean @default(false)
  barSetup                Boolean @default(false)
  onSiteCoordinator       Boolean @default(false)

  // Vendor Policy
  preferredVendorList     Boolean @default(false)
  outsideVendorsAllowed   Boolean @default(true)
  inHouseCateringRequired Boolean @default(false)
  byobPolicy              String?

  // Logistics
  setupHours     Float?
  teardownHours  Float?
  earliestStart  String?
  latestEnd      String?
  noiseOrdinance String?
  nearbyLodging  Boolean @default(false)

  // Booking
  leadTimeMonths     Int?
  cancellationPolicy String?

  // Aesthetics
  photoTags        String[]
  naturalLight     String? // "excellent" | "good" | "moderate" | "poor"
  indoorOutdoorMix String?

  // Accessibility
  adaCompliant   Boolean @default(false)
  elevatorAccess Boolean @default(false)

  // Social Proof
  googleRating       Float?
  googleReviews      Int?
  knotRating         Float?
  knotReviews        Int?
  weddingwireRating  Float?
  weddingwireReviews Int?
  featuredIn         String[]

  // Media
  primaryPhotoUrl String?
  photoCount      Int?
  virtualTourUrl  String?

  // Data Quality
  lastVerified      DateTime?
  dataSource        String?
  completenessScore Int?
  isPublished       Boolean  @default(false)

  // Audit
  lastAuditedAt       DateTime?
  auditScore          Int?
  auditStatus         String?   // "unaudited" | "clean" | "needs_review" | "flagged"
  auditFlags          Json?     // AuditFlag[]
  pipelineProcessedAt DateTime? // last time pipeline fully ran on this venue
  photoSource         String?   // "r2" | "website" | "places" | "manual"
  photoAuditedAt      DateTime? // last time photo was vision-scored

  // Description
  description String?

  // Monetization
  isFeatured    Boolean   @default(false)
  isHidden      Boolean   @default(false)  // Hidden from public, stays in DB
  deletedAt     DateTime?                  // Soft delete — reversible
  featuredUntil DateTime?

  // Relations
  inquiries   Inquiry[]
  owner       VenueOwner?
  claimTokens ClaimToken[]

  @@index([city])
  @@index([venueType])
  @@index([priceTier])
  @@index([isPublished])
  @@index([stateSlug])
  @@index([isFeatured])
}

model Inquiry {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venueId     String
  venue       Venue    @relation(fields: [venueId], references: [id])

  // Couple
  coupleName  String
  partnerName String?
  coupleEmail String
  couplePhone String?

  // Wedding details
  weddingDate         DateTime?
  weddingDateFlexible Boolean   @default(false)
  guestCount          Int?
  budgetMin           Int?
  budgetMax           Int?

  // Message
  message          String
  preferredContact String @default("email") // email | phone | either

  // Status
  status          String  @default("new") // new | viewed | responded | booked | lost
  venueNotified   Boolean @default(false)
  coupleConfirmed Boolean @default(false)

  // Tracking
  source String?

  @@index([venueId])
  @@index([status])
  @@index([createdAt])
}

model VenueOwner {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venueId String @unique
  venue   Venue  @relation(fields: [venueId], references: [id])

  email String @unique
  name  String?
  phone String?

  verified   Boolean   @default(false)
  verifiedAt DateTime?

  // Plan
  plan             String    @default("free") // free | featured | pro
  planStartedAt    DateTime?
  planExpiresAt    DateTime?
  stripeCustomerId String?
  stripeSubId      String?

  // Session (magic link)
  sessionToken   String?   @unique
  sessionExpires DateTime?
  lastLoginAt    DateTime?
}

model ClaimToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  @@index([token])
}
